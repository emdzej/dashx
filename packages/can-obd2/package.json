{
  "name": "@emdzej/dashx-can-obd2",
  "version": "0.2.1",
  "description": "OBD-II Mode 01 over CAN (ISO 15765-4) — ISO-TP single-frame encoder/decoder, Mode 01 PID library, request/response client. Used by DASHX to surface fuel trims, lambda voltage, battery voltage, and other diagnostic-only signals not on the broadcast bus.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@emdzej/dashx-can-decoder": "workspace:*",
    "@emdzej/dashx-can-transport": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/emdzej/dashx.git",
    "directory": "packages/can-obd2"
  },
  "license": "SEE LICENSE IN LICENSE"
}
