{
  "name": "@emdzej/dashx-widgets",
  "version": "0.1.0",
  "description": "Shared Svelte 5 dashboard widgets for DASHX — Gauge, Bar, Lamp, Value, FrameLog. Source-only; consumer apps' Vite + svelte plugin compiles them so HMR and tree-shake work end-to-end.",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "lint": "eslint 'src/**/*.ts'",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "svelte": "5.55.7",
    "svelte-check": "4.4.8",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/emdzej/dashx.git",
    "directory": "packages/widgets"
  },
  "license": "SEE LICENSE IN LICENSE"
}
