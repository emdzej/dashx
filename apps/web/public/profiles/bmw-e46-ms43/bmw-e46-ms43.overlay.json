{
  "source": "bmw-e46-ms43.dbc",
  "profile": {
    "id": "bmw-e46-ms43-dbc",
    "label": "BMW E46 MS43 (DBC + overlay)",
    "bitrate": 500000
  },
  "description": "BMW E46 with MS43 DME (M54, 2001-2006). Generated from the MS4X wiki canon; cross-checked against opencluster's e46_can_protocol.h. Use this profile to A/B-test the DBC+overlay code path against the hand-written TS profile.",

  "groups": [
    { "id": "dme",           "label": "DME — Engine",            "order": 100 },
    { "id": "dme-lamps",     "label": "DME — Cluster Lamps",     "order": 200 },
    { "id": "asc",           "label": "ASC / DSC",               "order": 300 },
    { "id": "steering",      "label": "Steering",                "order": 400 },
    { "id": "egs",           "label": "EGS / Transmission",      "order": 500 },
    { "id": "ike-cluster",   "label": "IKE — Cluster",           "order": 600 },
    { "id": "ike-body",      "label": "IKE — AC / Body",         "order": 700 }
  ],

