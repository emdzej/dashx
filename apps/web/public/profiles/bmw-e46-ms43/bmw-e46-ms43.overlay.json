  "derived": [
    {
      "id": "VEHICLE_SPEED",
      "label": "Speed",
      "unit": "km/h",
      "expr": "max(0, (VSS_RAW - 0x160) * 0.0625)",
      "description": "Vehicle speed VSS — DSC 13-bit raw with 0x160 noise-floor offset, clamped to non-negative. MS4X reports the offset; opencluster's transcription left it out.",
      "widget": "value",
      "fractionDigits": 0,
      "group": "asc"
    },
    {
      "id": "WHEEL_SPEED_1",
      "label": "W1",
      "unit": "km/h",
      "expr": "max(0, (WHEEL_SPEED_1_RAW - 44) / 15.875)",
      "description": "Front-left wheel speed (commonly). Raw 0x002C = 0 km/h per MS4X.",
      "widget": "value",
      "fractionDigits": 1,
      "group": "asc"
    },
    {
      "id": "WHEEL_SPEED_2",
      "label": "W2",
      "unit": "km/h",
      "expr": "max(0, (WHEEL_SPEED_2_RAW - 44) / 15.875)",
      "widget": "value",
      "fractionDigits": 1,
      "group": "asc"
    },
    {
      "id": "WHEEL_SPEED_3",
      "label": "W3",
      "unit": "km/h",
      "expr": "max(0, (WHEEL_SPEED_3_RAW - 44) / 15.875)",
      "widget": "value",
      "fractionDigits": 1,
      "group": "asc"
    },
    {
      "id": "WHEEL_SPEED_4",
      "label": "W4",
      "unit": "km/h",
      "expr": "max(0, (WHEEL_SPEED_4_RAW - 44) / 15.875)",
      "widget": "value",
      "fractionDigits": 1,
      "group": "asc"
    },
    {
      "id": "ODOMETER",
      "label": "Odo",
      "unit": "km",
      "expr": "ODOMETER_RAW",
      "description": "DBC already scales by 10 inline — this surfaces the value with a friendlier id + unit.",
      "widget": "value",
      "fractionDigits": 0,
      "group": "ike-cluster"
    },
    {
      "id": "CRUISE_ACTIVE",
      "label": "Cruise",
      "unit": "",
      "expr": "CRUISE_ACTIVE_STATE != 0",
      "description": "Convenience boolean — cruise control engaged whenever STATE_CRU_CAN is non-zero.",
      "widget": "lamp",
      "lampVariant": "info",
      "group": "dme"
    }
  ]
}
