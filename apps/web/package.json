{
  "name": "@emdzej/dashx-web",
  "version": "0.1.0",
  "description": "Browser SPA for DASHX — live CAN dashboard. Connect to a vehicle bus, decode broadcast frames, render gauges + lamps + frame log.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "build:embedded": "vite build --mode embedded",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit && svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "@emdzej/bimmerz-logger": "^0.1.2",
    "@emdzej/bimmerz-theme": "^0.1.0",
    "@emdzej/bimmerz-vfs": "^0.1.0",
    "@emdzej/dashx-can-decoder": "workspace:*",
    "@emdzej/dashx-can-obd2": "workspace:*",
    "@emdzej/dashx-can-transport": "workspace:*",
    "@emdzej/dashx-vehicles": "workspace:*",
    "@emdzej/dashx-widgets": "workspace:*",
    "svelte-dnd-action": "^0.9.70",
    "workbox-window": "^7.4.1"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tsconfig/svelte": "^5.0.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "svelte": "5.55.7",
    "svelte-check": "4.4.8",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^1.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/emdzej/dashx.git",
    "directory": "apps/web"
  },
